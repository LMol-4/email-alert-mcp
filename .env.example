# Auth (required) — callers must send this as `Authorization: Bearer <key>`
AUTH_API_KEY=

# Each channel below is enabled by setting its env vars. Leave a channel's
# vars unset to disable it. At least one channel must be configured.

# Email (via Resend — resend.com). ALERT_EMAIL may be a comma-separated list.
SENDING_EMAIL=
RESEND_API_KEY=
ALERT_EMAIL=

# Slack
SLACK_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS (via Twilio — twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=

# Generic webhook(s), comma-separated — receives the alert as JSON
WEBHOOK_URLS=
